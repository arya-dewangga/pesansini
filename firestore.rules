rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rooms
    match /rooms/{roomId} {
      // Anyone can read room details (to join via link)
      allow read: if true;
      
      // Only authenticated users can create rooms
      allow create: if request.auth != null;
      
      // Update logic:
      // 1. Host can update anything
      // 2. Public (guests) can ONLY update participantCount (when submitting order)
      allow update: if (request.auth != null && request.auth.uid == resource.data.hostUid) || 
                   (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantCount']));

      // Orders subcollection
      match /orders/{orderId} {
        // Anyone can read orders (Transparansi feature)
        allow read: if true;
        
        // Anyone can create an order
        allow create: if true;
        
        // Only authenticated users can update/delete (e.g. host or the user themselves)
        // You might want to refine this to only allow the creator to edit
        allow update, delete: if request.auth != null;
      }
    }
  }
}
